# 1 "/home/vvdn/zephyrproject/zephyr/include/zephyr/dt-bindings/gpio/arduino-header-r3.h" 1 3 4
# 8 "/home/vvdn/zephyrproject/zephyr/boards/st/nucleo_f446ze/arduino_r3_connector.dtsi" 2

/ {
 arduino_header: connector {
  compatible = "arduino-header-r3";
  #gpio-cells = <2>;
  gpio-map-mask = <0xffffffff 0xffffffc0>;
  gpio-map-pass-thru = <0 0x3f>;
  gpio-map = <0 0 &gpioa 3 0>,
      <1 0 &gpioc 0 0>,
      <2 0 &gpioc 3 0>,
      <3 0 &gpiof 3 0>,
      <4 0 &gpiof 5 0>,
      <5 0 &gpiof 10 0>,
      <6 0 &gpiog 9 0>,
      <7 0 &gpiog 14 0>,
      <8 0 &gpiof 15 0>,
      <9 0 &gpioe 13 0>,
      <10 0 &gpiof 14 0>,
      <11 0 &gpioe 11 0>,
      <12 0 &gpioe 9 0>,
      <13 0 &gpiof 13 0>,
      <14 0 &gpiof 12 0>,
      <15 0 &gpiod 15 0>,
      <16 0 &gpiod 14 0>,
      <17 0 &gpioa 7 0>,
      <18 0 &gpioa 6 0>,
      <19 0 &gpioa 5 0>,
      <20 0 &gpiob 9 0>,
      <21 0 &gpiob 8 0>;
 };
};

arduino_i2c: &i2c1 {};

arduino_spi: &spi1 {};

arduino_serial: &usart6 {};
