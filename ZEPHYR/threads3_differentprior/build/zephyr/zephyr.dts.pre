/ {
 model = "STMicroelectronics STM32F446ZE-NUCLEO board";
 compatible = "st,stm32f446ze-nucleo";

 chosen {
  zephyr,console = &usart3;
  zephyr,shell-uart = &usart3;
  zephyr,sram = &sram0;
  zephyr,flash = &flash0;
  zephyr,canbus = &can1;
 };

 leds: leds {
  compatible = "gpio-leds";

  green_led_1: led_1 {
   gpios = <&gpiob 0 (0 << 0)>;
   label = "User LD1";
  };

  blue_led_2: led_2 {
   gpios = <&gpiob 7 (0 << 0)>;
   label = "User LD2";
  };

  red_led_3: led_3 {
   gpios = <&gpiob 14 (0 << 0)>;
   label = "User LD3";
  };
 };

 gpio_keys {
  compatible = "gpio-keys";

  user_button: button {
   label = "User";
   gpios = <&gpioc 13 (1 << 0)>;
   zephyr,code = <11>;
  };
 };

 aliases {
  led0 = &green_led_1;
  led1 = &blue_led_2;
  led2 = &red_led_3;
  sw0 = &user_button;
  volt-sensor0 = &vref;
  volt-sensor1 = &vbat;
 };
};

&clk_lsi {
 status = "okay";
};

&clk_hse {
 hse-bypass;
 clock-frequency = <(((8) * 1000) * 1000)>;
 status = "okay";
};

&pll {
 div-m = <8>;
 mul-n = <336>;
 div-p = <2>;
 div-q = <7>;
 clocks = <&clk_hse>;
 status = "okay";
};

&rcc {
 clocks = <&pll>;
 clock-frequency = <(((168) * 1000) * 1000)>;
 ahb-prescaler = <1>;
 apb1-prescaler = <4>;
 apb2-prescaler = <2>;
};

&adc1 {
 pinctrl-0 = <&adc1_in0_pa0>;
 pinctrl-names = "default";
 st,adc-clock-source = "SYNC";
 st,adc-prescaler = <2>;
 status = "okay";
};

&dac1 {
 status = "okay";
 pinctrl-0 = <&dac_out1_pa4>;
 pinctrl-names = "default";
};

&usart2 {
 pinctrl-0 = <&usart2_tx_pd5 &usart2_rx_pd6>;
 pinctrl-names = "default";
 current-speed = <115200>;
 status = "okay";
};

&usart3 {
 pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
 pinctrl-names = "default";
 current-speed = <115200>;
 status = "okay";
};

&usart6 {
 pinctrl-0 = <&usart6_tx_pg14 &usart6_rx_pg9>;
 pinctrl-names = "default";
 current-speed = <115200>;
 status = "okay";
};

&i2c1 {
 pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
 pinctrl-names = "default";
 status = "okay";
 clock-frequency = <400000>;
};

&i2c2 {
 pinctrl-0 = <&i2c2_scl_pf1 &i2c2_sda_pf0>;
 pinctrl-names = "default";
 status = "okay";
 clock-frequency = <400000>;
};

&spi1 {
 pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
 pinctrl-names = "default";
 cs-gpios = <&gpiod 14 ((1 << 0) | (1 << 4))>;
 status = "okay";
};

&spi2 {
 pinctrl-0 = <&spi2_nss_pb12 &spi2_sck_pb13
       &spi2_miso_pb14 &spi2_mosi_pb15>;
 pinctrl-names = "default";
 status = "okay";
};

zephyr_udc0: &usbotg_fs {
 pinctrl-0 = <&usb_otg_fs_dm_pa11 &usb_otg_fs_dp_pa12
       &usb_otg_fs_id_pa10>;
 pinctrl-names = "default";
 status = "okay";
};

&timers1 {
 status = "okay";

 pwm1: pwm {
  status = "okay";
  pinctrl-0 = <&tim1_ch1_pe9>;
  pinctrl-names = "default";
 };
};

&rtc {
 clocks = <&rcc (0x040) (1 << 28)>,
   <&rcc 0x003 ((((0x70) & 0xFFFFU) << 0U) | (((8) & 0x1FU) << 16U) | ((((9) - (8)) & 0x3U) << 21U) | ((((2)) & 0xFFU) << 24U))>;
 status = "okay";
};

&backup_sram {
 status = "okay";
};

&can1 {
 pinctrl-0 = <&can1_rx_pd0 &can1_tx_pd1>;
 pinctrl-names = "default";
 status = "okay";
};

&flash0 {
 partitions {
  #address-cells = <1>;
  #size-cells = <1>;
  ranges;

  boot_partition: partition@0 {
   compatible = "zephyr,mapped-partition";
   label = "mcuboot";
   reg = <0x00000000 ((64) * 1024)>;
   read-only;
  };






  storage_partition: partition@10000 {
   compatible = "zephyr,mapped-partition";
   label = "storage";
   reg = <0x00010000 ((64) * 1024)>;
  };

  slot0_partition: partition@20000 {
   compatible = "zephyr,mapped-partition";
   label = "image-0";
   reg = <0x00020000 ((128) * 1024)>;
  };

  slot1_partition: partition@40000 {
   compatible = "zephyr,mapped-partition";
   label = "image-1";
   reg = <0x00040000 ((128) * 1024)>;
  };

  scratch_partition: partition@60000 {
   compatible = "zephyr,mapped-partition";
   label = "image-scratch";
   reg = <0x00060000 ((128) * 1024)>;
  };
 };
};

&vref {
 status = "okay";
};

&vbat {
 status = "okay";
};
# 0 "<command-line>" 2
# 1 "/home/vvdn/zephyrproject/zephyr/misc/empty_file.c"
